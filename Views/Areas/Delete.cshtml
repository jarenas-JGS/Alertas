@model Alertas.Models.Area

@{
    ViewData["Title"] = "Eliminar área";
    bool puedeEliminar = ViewBag.PuedeEliminar ?? false;
}

<div class="container mt-4">

    <h3>Eliminar área</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            @if (!puedeEliminar)
            {
                <div class="alert alert-warning">
                    Esta área no puede eliminarse porque tiene registros relacionados.
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    ¿Estás seguro de que deseas eliminar esta área?
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_area" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>

                    @if (puedeEliminar)
                    {
                        <button type="submit" class="btn btn-danger">
                            Eliminar
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>