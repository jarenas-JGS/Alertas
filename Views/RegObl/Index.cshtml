@model IEnumerable<Alertas.Models.RegObl>

@{
    ViewData["Title"] = "RegObl";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="fw-bold mb-1">Registro Obligaciones</h3>
                    <p class="text-muted mb-0">Listado de registros del módulo.</p>
                    
                </div>

                @if (ViewBag.PuedeCrearObligaciones == true)
                {
                    <a asp-controller="RegObl"
                       asp-action="Create"
                       class="btn btn-primary">
                        Crear obligación
                    </a>

                    <a asp-controller="ObligacionesCargaMasiva"
                       asp-action="Upload"
                       asp-route-idProyecto="@ViewBag.IdProyectoActivo"
                       class="btn btn-outline-success">
                        Cargue masivo
                    </a>

                    <form asp-controller="Notificaciones"
                          asp-action="Index"
                          method="post"
                          class="d-inline">

                        <input type="hidden" name="idProyecto" value="@ViewBag.IdProyecto" />

                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-envelope"></i>
                            Previsualizar notificaciones
                        </button>

                    </form>




                }
            </div>

            @if (TempData["Ok"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Ok"]
                </div>
            }

            <div class="table-responsive">
                <table id="tablaRegObl" class="table table-bordered align-middle w-100">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Nombre</th>
                            <th>Cliente</th>
                            <th>Empresa</th>
                            <th>Obligación</th>
                            <th>Estado</th>
                            <th>Fecha venc. obl.</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                        <tr class="filtros-columnas">
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Id" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Nombre" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Cliente" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Empresa" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Obligación" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Estado" /></th>
                            <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Fecha" /></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.id_reg_obl</td>
                                <td>@item.nombre</td>
                                <td>@item.Cliente?.nombre</td>
                                <td>@item.Empresa?.nombre</td>
                                <td>@item.TipoObligacion?.nombre</td>
                                <td>@item.Estado?.nombre</td>
                                <td>@item.fecha_venc_obl.ToString("yyyy-MM-dd")</td>
                                <td class="text-center">
                                    <a asp-action="Seguimiento"
                                       asp-route-id="@item.id_reg_obl"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Seguimiento">
                                        <i class="bi bi-search"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


    <style>
        #tablaRegObl thead .filtros-columnas th {
            padding: 0.4rem;
            background-color: #f8f9fa;
        }

        #tablaRegObl thead .filtros-columnas input {
            min-width: 100%;
        }

        #tablaRegObl_wrapper .dataTables_filter input {
            margin-left: 0.5rem;
        }

        #tablaRegObl_wrapper .dataTables_length select {
            margin: 0 0.4rem;
        }

        #tablaRegObl_wrapper .dataTables_info,
        #tablaRegObl_wrapper .dataTables_paginate {
            margin-top: 0.75rem;
        }
    </style>


@section Scripts {
    <script>
        $(document).ready(function () {
            var tabla = $('#tablaRegObl').DataTable({
                pageLength: 10,
                lengthMenu: [10, 20, 50, 100],
                orderCellsTop: true,
                language: {
                    decimal: "",
                    emptyTable: "No hay información",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    infoEmpty: "Mostrando 0 a 0 de 0 registros",
                    infoFiltered: "(filtrado de _MAX_ registros totales)",
                    lengthMenu: "Mostrar _MENU_ registros",
                    loadingRecords: "Cargando...",
                    processing: "Procesando...",
                    search: "Buscar:",
                    zeroRecords: "No se encontraron resultados",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 8 }
                ]
            });

            $('#tablaRegObl thead tr.filtros-columnas th').each(function (i) {
                var input = $('input', this);

                if (input.length) {
                        input.on('keyup change clear', function () {
                        if (tabla.column(i).search() !== this.value) {
                            tabla.column(i).search(this.value).draw();
                        }
                    });
                }
            });
        });
    </script>
}