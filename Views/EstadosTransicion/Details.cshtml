@model Alertas.Models.EstadoTransicion

@{
    ViewData["Title"] = "Consultar transición de estado";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar transición de estado</h3>
            <small class="text-muted">Detalle de la información registrada para la transición.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información de la transición
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.id_estado_transicion</dd>

                <dt class="col-sm-3">Proyecto</dt>
                <dd class="col-sm-9">@Model.Proyecto?.nombre</dd>

                <dt class="col-sm-3">Estado origen</dt>
                <dd class="col-sm-9">@Model.EstadoOrigen?.nombre</dd>

                <dt class="col-sm-3">Estado destino</dt>
                <dd class="col-sm-9">@Model.EstadoDestino?.nombre</dd>

                <dt class="col-sm-3">Nombre acción</dt>
                <dd class="col-sm-9">@Model.nombre_accion</dd>

                <dt class="col-sm-3">Orden</dt>
                <dd class="col-sm-9">@Model.orden</dd>

                <dt class="col-sm-3">Requiere observación</dt>
                <dd class="col-sm-9">@(Model.requiere_observacion ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Es aprobación</dt>
                <dd class="col-sm-9">@(Model.es_aprobacion ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Es rechazo</dt>
                <dd class="col-sm-9">@(Model.es_rechazo ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Es anulación</dt>
                <dd class="col-sm-9">@(Model.es_anulacion ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Relaciones asociadas
        </div>

        <div class="card-body">
            <p class="text-muted mb-3">
                Esta información muestra los roles asociados a la transición del workflow.
            </p>

            @if (Model.RolesEstadosTransicion != null && Model.RolesEstadosTransicion.Any())
            {
                <table class="table table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Rol</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RolesEstadosTransicion)
                        {
                            <tr>
                                <td>@item.Rol?.nombre</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No hay roles asociados a esta transición.</p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_estado_transicion" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
    </div>
</div>