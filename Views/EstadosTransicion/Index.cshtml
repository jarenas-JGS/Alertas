@model IEnumerable<Alertas.Models.EstadoTransicion>

@{
    ViewData["Title"] = "Transiciones de estado";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Transiciones de estado</h3>
            <small class="text-muted">Administración controlada de transiciones por proyecto.</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table id="tablaEstadosTransicion" class="table table-bordered align-middle w-100">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Proyecto</th>
                        <th>Orden</th>
                        <th>Estado origen</th>
                        <th>Estado destino</th>
                        <th>Acción</th>
                        <th>Observación</th>
                        <th>Aprobación</th>
                        <th>Rechazo</th>
                        <th>Anulación</th>
                        <th>Estado</th>
                        <th class="text-end" style="width: 220px;">Acciones</th>
                    </tr>
                    <tr class="filtros-columnas">
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Id" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Proyecto" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Orden" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Origen" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Destino" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Acción" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Observación" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Aprobación" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Rechazo" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Anulación" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Estado" /></th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.id_estado_transicion</td>
                                <td>@item.Proyecto?.nombre</td>
                                <td>@item.orden</td>
                                <td>@item.EstadoOrigen?.nombre</td>
                                <td>@item.EstadoDestino?.nombre</td>
                                <td>@item.nombre_accion</td>
                                <td>@(item.requiere_observacion ? "Sí" : "No")</td>
                                <td>@(item.es_aprobacion ? "Sí" : "No")</td>
                                <td>@(item.es_rechazo ? "Sí" : "No")</td>
                                <td>@(item.es_anulacion ? "Sí" : "No")</td>
                                <td>
                                    @if (item.activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 flex-nowrap">
                                        <a asp-action="Details" asp-route-id="@item.id_estado_transicion"
                                           class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                                            <i class="bi bi-eye"></i>
                                            <span>Consultar</span>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.id_estado_transicion"
                                           class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                            <i class="bi bi-pencil"></i>
                                            <span>Editar</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    #tablaEstadosTransicion thead .filtros-columnas th {
        padding: 0.4rem;
        background-color: #f8f9fa;
    }

    #tablaEstadosTransicion thead .filtros-columnas input {
        min-width: 100%;
    }

    #tablaEstadosTransicion_wrapper .dataTables_filter input {
        margin-left: 0.5rem;
    }

    #tablaEstadosTransicion_wrapper .dataTables_length select {
        margin: 0 0.4rem;
    }

    #tablaEstadosTransicion_wrapper .dataTables_info,
    #tablaEstadosTransicion_wrapper .dataTables_paginate {
        margin-top: 0.75rem;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            var tabla = $('#tablaEstadosTransicion').DataTable({
                pageLength: 10,
                lengthMenu: [10, 20, 50, 100],
                orderCellsTop: true,
                language: {
                    decimal: "",
                    emptyTable: "No hay información",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    infoEmpty: "Mostrando 0 a 0 de 0 registros",
                    infoFiltered: "(filtrado de _MAX_ registros totales)",
                    lengthMenu: "Mostrar _MENU_ registros",
                    loadingRecords: "Cargando...",
                    processing: "Procesando...",
                    search: "Buscar:",
                    zeroRecords: "No se encontraron resultados",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 11 }
                ]
            });

            $('#tablaEstadosTransicion thead tr.filtros-columnas th').each(function (i) {
                var input = $('input', this);

                if (input.length) {
                    input.on('keyup change clear', function () {
                        if (tabla.column(i).search() !== this.value) {
                            tabla.column(i).search(this.value).draw();
                        }
                    });
                }
            });
        });
    </script>
}