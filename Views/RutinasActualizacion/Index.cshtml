@model Alertas.ViewModels.RutinasActualizacion.RutinaParticipantesVm

@{
    ViewData["Title"] = "Rutinas de actualización";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>
                <i class="bi bi-arrow-repeat me-2"></i>
                Rutinas de actualización
            </h3>
            <small class="text-muted">
                Inclusión, eliminación o cambio masivo de participantes en obligaciones.
            </small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Preview" method="post" id="frmRutina">

                @Html.AntiForgeryToken()

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Proyecto</label>

                        <select asp-for="IdProyecto"
                                asp-items="Model.Proyectos"
                                class="form-select"
                                id="IdProyecto">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdProyecto"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Empresa</label>

                        <select asp-for="IdEmpresa"
                                class="form-select"
                                id="IdEmpresa">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdEmpresa"
                              class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Rol</label>

                        <select asp-for="IdRol"
                                asp-items="Model.Roles"
                                class="form-select"
                                id="IdRol">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdRol"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Acción</label>

                        <select asp-for="Accion"
                                class="form-select"
                                id="Accion">

                            <option value="">Seleccione...</option>

                            <option value="INCLUIR">
                                Incluir
                            </option>

                            <option value="ELIMINAR">
                                Eliminar
                            </option>

                            <option value="CAMBIAR">
                                Cambiar
                            </option>

                        </select>

                        <span asp-validation-for="Accion"
                              class="text-danger"></span>
                    </div>

                </div>

                <div id="divUsuarioOrigen" style="display:none;">

                    <div class="mb-3">

                        <label class="form-label">
                            Usuario actual
                        </label>

                        <select asp-for="IdUsuarioOrigen"
                                class="form-select"
                                id="IdUsuarioOrigen">
                            <option value="">Seleccione...</option>
                        </select>

                    </div>

                </div>

                <div id="divUsuarioDestino" style="display:none;">

                    <div class="mb-3">

                        <label class="form-label"
                               id="lblUsuarioDestino">
                            Usuario
                        </label>

                        <select asp-for="IdUsuarioDestino"
                                class="form-select"
                                id="IdUsuarioDestino">
                            <option value="">Seleccione...</option>
                        </select>

                    </div>

                </div>

                <hr />

                <button type="submit"
                        class="btn btn-primary">

                    <i class="bi bi-search me-1"></i>
                    Generar preview

                </button>

            </form>

        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            $('#IdProyecto').change(function () {
                limpiarEmpresas();
                limpiarUsuarios();

                let proyecto = $(this).val();

                if (!proyecto)
                    return;

                $.get('/RutinasActualizacion/ObtenerEmpresasProyecto',
                    { idProyecto: proyecto },
                    function (data) {
                        $.each(data, function (i, item) {
                            $('#IdEmpresa').append(
                                `<option value="${item.id}">${item.nombre}</option>`);
                        });

                        refrescarUsuariosSegunAccion();
                    });
            });

            $('#IdEmpresa, #IdRol, #Accion').change(function () {
                refrescarUsuariosSegunAccion();
            });

            function refrescarUsuariosSegunAccion() {
                let accion = $('#Accion').val();

                $('#divUsuarioOrigen').hide();
                $('#divUsuarioDestino').hide();

                limpiarUsuarios();

                if (accion === 'INCLUIR') {
                    $('#divUsuarioDestino').show();
                    $('#lblUsuarioDestino').text('Usuario a incluir');
                    cargarUsuariosArea();
                }

                if (accion === 'ELIMINAR') {
                    $('#divUsuarioOrigen').show();
                    cargarUsuariosRol();
                }

                if (accion === 'CAMBIAR') {
                    $('#divUsuarioOrigen').show();
                    $('#divUsuarioDestino').show();
                    $('#lblUsuarioDestino').text('Usuario nuevo');

                    cargarUsuariosRol();
                    cargarUsuariosArea();
                }
            }

            function cargarUsuariosArea() {
                let proyecto = $('#IdProyecto').val();

                if (!proyecto)
                    return;

                $.get('/RutinasActualizacion/ObtenerUsuariosArea',
                    { idProyecto: proyecto },
                    function (data) {
                        $('#IdUsuarioDestino')
                            .empty()
                            .append('<option value="">Seleccione...</option>');

                        $.each(data, function (i, item) {
                            $('#IdUsuarioDestino').append(
                                `<option value="${item.id}">${item.nombre}</option>`);
                        });
                    });
            }

            function cargarUsuariosRol() {
                let proyecto = $('#IdProyecto').val();
                let empresa = $('#IdEmpresa').val();
                let rol = $('#IdRol').val();

                if (!proyecto || !empresa || !rol)
                    return;

                $.get('/RutinasActualizacion/ObtenerUsuariosRol',
                    {
                        idProyecto: proyecto,
                        idEmpresa: empresa,
                        idRol: rol
                    },
                    function (data) {
                        $('#IdUsuarioOrigen')
                            .empty()
                            .append('<option value="">Seleccione...</option>');

                        $.each(data, function (i, item) {
                            $('#IdUsuarioOrigen').append(
                                `<option value="${item.id}">${item.nombre}</option>`);
                        });
                    });
            }

            function limpiarEmpresas() {
                $('#IdEmpresa')
                    .empty()
                    .append('<option value="">Seleccione...</option>');
            }

            function limpiarUsuarios() {
                $('#IdUsuarioOrigen')
                    .empty()
                    .append('<option value="">Seleccione...</option>');

                $('#IdUsuarioDestino')
                    .empty()
                    .append('<option value="">Seleccione...</option>');
            }
        });
    </script>
}