@model Alertas.ViewModels.Notificaciones.HistorialCorreosViewModel

@{
    ViewData["Title"] = "Historial de Correos";
}

<div class="container mt-4">

    <div class="mb-3">
        <h3 class="mb-1">
            <i class="bi bi-envelope-paper me-2"></i>Historial de Correos
        </h3>
        <small class="text-muted">
            Consulta de correos enviados por alertas manuales, automáticas y pruebas controladas.
        </small>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Últimos correos registrados</strong>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaCorreos" class="table table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha envío</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Proyecto</th>
                            <th>Usuario</th>
                            <th>Destinatario</th>
                            <th>Asunto</th>
                            <th>Alertas</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Correos)
                        {
                            var estadoClass = item.EstadoEnvio switch
                            {
                                "ENVIADO" => "badge bg-success",
                                "ERROR" => "badge bg-danger",
                                "SIN_ALERTAS" => "badge bg-secondary",
                                _ => "badge bg-secondary"
                            };

                            var estadoTexto = item.EstadoEnvio switch
                            {
                                "ENVIADO" => "Enviado",
                                "ERROR" => "Error",
                                "SIN_ALERTAS" => "Sin alertas",
                                _ => item.EstadoEnvio
                            };

                            <tr>
                                <td>@item.FechaEnvio.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@item.TipoEjecucion</td>
                                <td><span class="@estadoClass">@estadoTexto</span></td>
                                <td>@item.NombreProyecto</td>
                                <td>@item.NombreUsuario</td>
                                <td>@item.DestinatarioEmail</td>
                                <td>@item.Asunto</td>
                                <td class="text-center">@item.CantidadAlertas</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.ErrorMensaje))
                                    {
                                        <span title="@item.ErrorMensaje">
                                            @(item.ErrorMensaje.Length > 80
                                                                                ? item.ErrorMensaje.Substring(0, 80) + "..."
                                                                                : item.ErrorMensaje)
                                </span>
                                                                }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaCorreos').DataTable({
                order: [[0, 'desc']],
                pageLength: 25,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}