@model Alertas.ViewModels.Notificaciones.HistorialCorreoDetalleViewModel

@{
    ViewData["Title"] = "Detalle del Correo";
}

<div class="container mt-4">

    <div class="mb-3">
        <h3 class="mb-1">
            <i class="bi bi-envelope-open me-2"></i>Detalle del Correo
        </h3>
        <small class="text-muted">
            Consulta del envío y las alertas incluidas en el correo.
        </small>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <strong>Información del envío</strong>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Fecha envío</dt>
                <dd class="col-sm-9">@Model.FechaEnvio.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                <dt class="col-sm-3">Tipo ejecución</dt>
                <dd class="col-sm-9">@Model.TipoEjecucion</dd>

                <dt class="col-sm-3">Estado</dt>
                <dd class="col-sm-9">@Model.EstadoEnvio</dd>

                <dt class="col-sm-3">Proyecto</dt>
                <dd class="col-sm-9">@Model.NombreProyecto</dd>

                <dt class="col-sm-3">Usuario</dt>
                <dd class="col-sm-9">@Model.NombreUsuario</dd>

                <dt class="col-sm-3">Destinatario</dt>
                <dd class="col-sm-9">@Model.DestinatarioEmail</dd>

                <dt class="col-sm-3">Asunto</dt>
                <dd class="col-sm-9">@Model.Asunto</dd>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMensaje))
                {
                    <dt class="col-sm-3">Error</dt>
                    <dd class="col-sm-9 text-danger">@Model.ErrorMensaje</dd>
                }
            </dl>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Alertas incluidas</strong>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaDetalleAlertas" class="table table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Prioridad</th>
                            <th>Alerta</th>
                            <th>Mensaje</th>
                            <th>Obligación</th>
                            <th>Fecha venc obligación</th>
                            <th>Días venc obligación</th>
                            <th>Fecha venc seguimiento</th>
                            <th>Días venc seguimiento</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Alertas)
                        {
                            <tr>
                                <td>@item.Prioridad</td>
                                <td>@item.NombreAlerta</td>
                                <td>@item.NombreMensaje</td>
                                <td>
                                    <span class="fw-semibold">
                                        @item.IdRegObl
                                    </span>

                                    @if (!string.IsNullOrWhiteSpace(item.NombreObligacion))
                                    {
                                        <span class="text-muted">
                                            - @item.NombreObligacion
                                        </span>
                                    }
                                </td>
                                <td>@item.FechaVencObl?.ToString("dd/MM/yyyy")</td>
                                <td>@item.DiasVencimientoObl</td>
                                <td>@item.FechaVencSeguimiento?.ToString("dd/MM/yyyy")</td>
                                <td>@item.DiasVencimientoSeguimiento</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaDetalleAlertas').DataTable({
                pageLength: 25,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}