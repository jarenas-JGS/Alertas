@model IEnumerable<Alertas.Models.Dominio>

@{
    ViewData["Title"] = "Dominios";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Dominios</h3>
            <small class="text-muted">Administración de dominios del sistema.</small>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo dominio
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th class="text-end" style="width: 280px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted">
                                No hay dominios registrados.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.nombre</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 flex-nowrap">
                                        <a asp-action="Details" asp-route-id="@item.id_dominio"
                                           class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                                            <i class="bi bi-eye"></i>
                                            <span>Consultar</span>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.id_dominio"
                                           class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                            <i class="bi bi-pencil"></i>
                                            <span>Editar</span>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.id_dominio"
                                           class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1">
                                            <i class="bi bi-trash"></i>
                                            <span>Eliminar</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>