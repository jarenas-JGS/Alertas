@model Alertas.ViewModels.RolEditViewModel

@{
    ViewData["Title"] = "Editar rol";
}

<div class="container mt-4">

    <h3>Editar rol</h3>
    <p class="text-muted">
        Solo se permite modificar el estado activo. El nombre del rol no debe cambiarse porque es usado por la lógica interna de la aplicación.
    </p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_rol" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Id</label>
                    <input value="@Model.id_rol" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Rol</label>
                    <input value="@Model.nombre" class="form-control" disabled />
                    <small class="text-muted">
                        Este nombre está protegido porque puede afectar funcionalidades de la aplicación.
                    </small>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Activo</label>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>