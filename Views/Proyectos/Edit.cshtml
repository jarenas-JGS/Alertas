@model Alertas.ViewModels.ProyectoEditViewModel

@{
    ViewData["Title"] = "Editar proyecto";
}

<div class="container mt-4">

    <h3>Editar proyecto</h3>
    <p class="text-muted">
        Solo se permite modificar el nombre, nombre de seguimiento y estado activo. Los cambios estructurales deben hacerse desde el Wizard.
    </p>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_proyecto" />
                <input type="hidden" asp-for="id_area" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Área</label>
                    <input value="@Model.nombre_area" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="200" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="nombre_seguimiento" class="form-label">Nombre seguimiento</label>
                    <input asp-for="nombre_seguimiento" class="form-control" maxlength="150" />
                    <span asp-validation-for="nombre_seguimiento" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <div><strong>Fecha creación:</strong> @Model.fecha_creacion.ToString("yyyy-MM-dd HH:mm")</div>
                        <div><strong>Usuario creación:</strong> @Model.usuario_creacion</div>
                        <div><strong>Configuración completa:</strong> @(Model.configuracion_completa ? "Sí" : "No")</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.puedeReabrirWizard)
    {
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">
                Configuración estructural
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Este proyecto aún no tiene obligaciones creadas. Puedes pasarlo a configuración incompleta para modificar área, estados, transiciones, reglas, usuarios y demás configuración desde el Wizard.
                </p>

                <form asp-action="ReabrirConfiguracionProyecto" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="idProyecto" value="@Model.id_proyecto" />

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-outline-warning">
                            Pasar proyecto a configuración incompleta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}