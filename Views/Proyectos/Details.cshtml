@model Alertas.Models.Proyecto

@{
    ViewData["Title"] = "Consultar proyecto";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar proyecto</h3>
            <small class="text-muted">Detalle de la información registrada para el proyecto.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información del proyecto
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.id_proyecto</dd>

                <dt class="col-sm-3">Área</dt>
                <dd class="col-sm-9">@Model.Area?.nombre</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>

                <dt class="col-sm-3">Nombre seguimiento</dt>
                <dd class="col-sm-9">@Model.nombre_seguimiento</dd>

                <dt class="col-sm-3">Fecha creación</dt>
                <dd class="col-sm-9">@Model.fecha_creacion.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-3">Usuario creación</dt>
                <dd class="col-sm-9">@Model.UsuarioCreacion?.nombre</dd>

                <dt class="col-sm-3">Configuración completa</dt>
                <dd class="col-sm-9">@(Model.configuracion_completa ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Relaciones asociadas
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Obligaciones</dt>
                <dd class="col-sm-8">@Model.Obligaciones.Count</dd>

                <dt class="col-sm-4">Estados</dt>
                <dd class="col-sm-8">@Model.Estados.Count</dd>

                <dt class="col-sm-4">Transiciones de estado</dt>
                <dd class="col-sm-8">@Model.EstadosTransicion.Count</dd>

                <dt class="col-sm-4">Grupos de alerta</dt>
                <dd class="col-sm-8">@Model.GruposAlertas.Count</dd>

                <dt class="col-sm-4">Usuarios asociados</dt>
                <dd class="col-sm-8">@Model.UsuariosProyectos.Count</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_proyecto" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Delete" asp-route-id="@Model.id_proyecto" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Eliminar
        </a>
    </div>
</div>