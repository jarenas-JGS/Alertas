@model Alertas.Models.Mensaje

@{
    ViewData["Title"] = "Consultar mensaje";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar mensaje</h3>
            <small class="text-muted">Detalle de la información registrada para el mensaje.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información del mensaje
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.id_mensaje</dd>

                <dt class="col-sm-3">Prioridad</dt>
                <dd class="col-sm-9">@Model.prioridad</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>

                <dt class="col-sm-3">Texto</dt>
                <dd class="col-sm-9">@Model.texto</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Relaciones asociadas
        </div>

        <div class="card-body">
            @if (Model.GruposAlertasDias != null && Model.GruposAlertasDias.Any())
            {
                <div class="alert alert-info mb-0">
                    Este mensaje tiene @Model.GruposAlertasDias.Count alerta(s) por días asociada(s).
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Este mensaje no tiene alertas por días asociadas.</p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_mensaje" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Delete" asp-route-id="@Model.id_mensaje" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Eliminar
        </a>
    </div>
</div>