@model Alertas.ViewModels.EmpresaViewModel

@{
    ViewData["Title"] = "Nueva empresa";
}

<div class="container mt-4">

    <h3>Nueva empresa</h3>
    <p class="text-muted">Crea una nueva empresa asociada a un cliente.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="nit" class="form-label">NIT</label>
                    <input asp-for="nit" class="form-control" maxlength="30" />
                    <span asp-validation-for="nit" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Ult Dig</label>
                    <input class="form-control" value="Se calculará automáticamente desde el NIT" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="100" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="email" class="form-label">Email</label>
                    <input asp-for="email" class="form-control" maxlength="70" />
                    <span asp-validation-for="email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="id_cliente" class="form-label">Cliente</label>
                    <select asp-for="id_cliente" asp-items="Model.Clientes" class="form-select">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="id_cliente" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                    <span asp-validation-for="activo" class="text-danger d-block"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}