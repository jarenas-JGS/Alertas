@model Alertas.Models.Cliente

@{
    ViewData["Title"] = "Nuevo cliente";
}

<div class="container mt-4">

    <h3>Nuevo cliente</h3>
    <p class="text-muted">Crea un nuevo cliente para usarlo en la gestión de obligaciones.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="nit" class="form-label">NIT</label>
                    <input asp-for="nit" class="form-control" maxlength="100" />
                    <span asp-validation-for="nit" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="dig_verif" class="form-label">DV</label>
                    <input asp-for="dig_verif" class="form-control" />
                    <span asp-validation-for="dig_verif" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="100" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                    <span asp-validation-for="activo" class="text-danger d-block"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}