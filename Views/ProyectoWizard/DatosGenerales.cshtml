@model Alertas.ViewModels.ProyectoWizard.ProyectoWizardDatosGeneralesVm

@{
    ViewData["Title"] = "Wizard de proyecto - Datos generales";
}

<h2>Creación de proyecto</h2>

<div class="card shadow-sm">
    <div class="card-header">
        <strong>Paso 1 de 10 - Datos generales</strong>
    </div>

    <div class="card-body">
        <form asp-action="DatosGenerales" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="id_proyecto" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="nombre" class="form-label"></label>
                <input asp-for="nombre" class="form-control" />
                <span asp-validation-for="nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="id_area" class="form-label"></label>
                <select asp-for="id_area" asp-items="Model.Areas" class="form-select">
                    <option value="">Seleccione...</option>
                </select>
                <span asp-validation-for="id_area" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="nombre_seguimiento" class="form-label"></label>
                <input asp-for="nombre_seguimiento" class="form-control" />
                <span asp-validation-for="nombre_seguimiento" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-controller="ProyectoWizard" asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-primary">
                    Guardar y continuar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}