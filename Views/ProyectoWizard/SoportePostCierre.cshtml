@model Alertas.ViewModels.ProyectoWizard.ProyectoWizardSoportePostCierreVm

@{
    ViewData["Title"] = "Wizard de proyecto - Soporte posterior al cierre";
}

<h2>Creación de proyecto</h2>

<div class="card shadow-sm">
    <div class="card-header">
        <strong>Paso 5 de 10 - Soporte posterior al cierre</strong>
        <div class="text-muted">Proyecto: @Model.nombre_proyecto</div>
    </div>

    <div class="card-body">
        <form asp-action="SoportePostCierre" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="id_proyecto" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="alert alert-info">
                Esta opción no crea estados ni transiciones. Solo habilita una opción funcional para registrar información adicional después de que la obligación esté cerrada.
            </div>

            <div class="form-check mb-3">
                <input asp-for="usa_soporte_post_cierre" class="form-check-input" id="chkSoportePostCierre" />
                <label asp-for="usa_soporte_post_cierre" class="form-check-label"></label>
            </div>

            <div class="mb-3" id="contenedorNombreSoporte">
                <label asp-for="nombre_soporte_post_cierre" class="form-label"></label>
                <input asp-for="nombre_soporte_post_cierre" class="form-control" placeholder="Ej: Pago, Legalización, Soportes finales" />
                <span asp-validation-for="nombre_soporte_post_cierre" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="RolesTransicion" asp-route-id="@Model.id_proyecto" class="btn btn-secondary">
                    Anterior
                </a>

                <button type="submit" class="btn btn-primary">
                    Guardar y continuar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function actualizarVisibilidadSoporte() {
            const checked = document.getElementById("chkSoportePostCierre").checked;
            document.getElementById("contenedorNombreSoporte").style.display = checked ? "block" : "none";
        }

        document.getElementById("chkSoportePostCierre")
            .addEventListener("change", actualizarVisibilidadSoporte);

        actualizarVisibilidadSoporte();
    </script>
}