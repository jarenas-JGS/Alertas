@model Alertas.ViewModels.ProyectoWizard.ProyectoWizardGrupoAlertasVm

@{
    ViewData["Title"] = "Wizard de proyecto - Grupo de alertas";
}

<h2>Creación de proyecto</h2>

<div class="card shadow-sm">
    <div class="card-header">
        <strong>Paso 6 de 10 - Grupo de alertas</strong>
        <div class="text-muted">Proyecto: @Model.nombre_proyecto</div>
    </div>

    <div class="card-body">
        <form asp-action="GrupoAlertas" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="id_proyecto" />
            <input type="hidden" asp-for="id_grupo_alerta" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="nombre" class="form-label">Nombre del grupo de alertas</label>
                <input asp-for="nombre" class="form-control" />
                <span asp-validation-for="nombre" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="activo" class="form-check-input" />
                <label asp-for="activo" class="form-check-label">Activo</label>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="SoportePostCierre" asp-route-id="@Model.id_proyecto" class="btn btn-secondary">
                    Anterior
                </a>

                <button type="submit" class="btn btn-primary">
                    Guardar y continuar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}