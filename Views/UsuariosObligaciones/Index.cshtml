@model IEnumerable<Alertas.Models.UsuarioObligacion>

@{
    ViewData["Title"] = "Usuarios por obligación";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Usuarios por obligación</h3>
            <small class="text-muted">Consulta de usuarios asociados a obligaciones.</small>
        </div>
    </div>

    <div class="alert alert-info">
        La creación, edición y eliminación de usuarios asociados a obligaciones se realiza desde el manejo de la obligación.
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table id="tablaUsuariosObligaciones" class="table table-bordered align-middle w-100">
                <thead class="table-light">
                    <tr>
                        <th>Proyecto</th>
                        <th>Id obligación</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Fecha asignación</th>
                        <th>Asignado por</th>
                        <th>Estado</th>
                        <th class="text-end" style="width: 160px;">Acciones</th>
                    </tr>
                    <tr class="filtros-columnas">
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Proyecto" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Obligación" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Usuario" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Rol" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Fecha" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Asignado" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Buscar Estado" /></th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RegObl?.Proyecto?.nombre</td>
                                <td>@item.id_reg_obl</td>
                                <td>@item.Usuario?.nombre</td>
                                <td>@item.Rol?.nombre</td>
                                <td>@(item.fecha_asignacion?.ToString("yyyy-MM-dd HH:mm") ?? "Sin registro")</td>
                                <td>@(item.UsuarioAsignacion?.nombre ?? "Sin registro")</td>
                                <td>
                                    @if (item.activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.id_usuario_obligacion"
                                       class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-eye"></i>
                                        <span>Consultar</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    #tablaUsuariosObligaciones thead .filtros-columnas th {
        padding: 0.4rem;
        background-color: #f8f9fa;
    }

    #tablaUsuariosObligaciones thead .filtros-columnas input {
        min-width: 100%;
    }

    #tablaUsuariosObligaciones_wrapper .dataTables_filter input {
        margin-left: 0.5rem;
    }

    #tablaUsuariosObligaciones_wrapper .dataTables_length select {
        margin: 0 0.4rem;
    }

    #tablaUsuariosObligaciones_wrapper .dataTables_info,
    #tablaUsuariosObligaciones_wrapper .dataTables_paginate {
        margin-top: 0.75rem;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            var tabla = $('#tablaUsuariosObligaciones').DataTable({
                pageLength: 10,
                lengthMenu: [10, 20, 50, 100],
                orderCellsTop: true,
                language: {
                    decimal: "",
                    emptyTable: "No hay información",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    infoEmpty: "Mostrando 0 a 0 de 0 registros",
                    infoFiltered: "(filtrado de _MAX_ registros totales)",
                    lengthMenu: "Mostrar _MENU_ registros",
                    loadingRecords: "Cargando...",
                    processing: "Procesando...",
                    search: "Buscar:",
                    zeroRecords: "No se encontraron resultados",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 7 }
                ]
            });

            $('#tablaUsuariosObligaciones thead tr.filtros-columnas th').each(function (i) {
                var input = $('input', this);

                if (input.length) {
                    input.on('keyup change clear', function () {
                        if (tabla.column(i).search() !== this.value) {
                            tabla.column(i).search(this.value).draw();
                        }
                    });
                }
            });
        });
    </script>
}