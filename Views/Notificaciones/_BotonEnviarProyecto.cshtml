@model int?

@if (Model.HasValue)
{
    <div class="mb-3" style="max-width: 320px;">
        <form asp-controller="Notificaciones"
              asp-action="EnviarManualProyecto"
              method="post"
              class="form-proceso-notificaciones">
            @Html.AntiForgeryToken()

            <input type="hidden" name="idProyecto" value="@Model.Value" />

            <button type="submit" class="btn-notif btn-outline-success-custom w-100">
                <i class="bi bi-send me-1"></i>
                Enviar correos del proyecto
            </button>
        </form>
    </div>
}