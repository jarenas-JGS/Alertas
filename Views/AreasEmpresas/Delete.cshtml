@model Alertas.Models.AreaEmpresa

@{
    ViewData["Title"] = "Eliminar Área - Empresa";
    bool puedeEliminar = ViewBag.PuedeEliminar ?? false;
}

<div class="container mt-4">

    <h3>Eliminar Área - Empresa</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            @if (!puedeEliminar)
            {
                <div class="alert alert-warning">
                    Este registro no puede eliminarse porque existen obligaciones asociadas a esta área y empresa.
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    ¿Estás seguro de que deseas eliminar este registro?
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Área</dt>
                <dd class="col-sm-9">@Model.Area?.nombre</dd>

                <dt class="col-sm-3">Empresa</dt>
                <dd class="col-sm-9">@Model.Empresa?.nombre</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.email</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_area_empresa" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>

                    @if (puedeEliminar)
                    {
                        <button type="submit" class="btn btn-danger">
                            Eliminar
                        </button>
                    }
                </div>
            </form>

        </div>
    </div>
</div>