@model Alertas.Models.AreaEmpresa

@{
    ViewData["Title"] = "Consultar Área - Empresa";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar registro</h3>
            <small class="text-muted">Detalle de la asociación Área - Empresa.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <!-- INFORMACIÓN PRINCIPAL -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información general
        </div>

        <div class="card-body">
            <dl class="row mb-0">

                <dt class="col-sm-3">Área</dt>
                <dd class="col-sm-9">@Model.Area?.nombre</dd>

                <dt class="col-sm-3">Empresa</dt>
                <dd class="col-sm-9">@Model.Empresa?.nombre</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.email</dd>

                <dt class="col-sm-3">Estado</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>

            </dl>
        </div>
    </div>

    <!-- ACCIONES -->
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_area_empresa" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Delete" asp-route-id="@Model.id_area_empresa" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Inactivar
        </a>
    </div>

</div>