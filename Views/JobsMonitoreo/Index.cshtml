@model Alertas.ViewModels.Jobs.JobsMonitoreoIndexViewModel

@{
    ViewData["Title"] = "Monitoreo de Jobs";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">
                <i class="bi bi-activity me-2"></i>Monitoreo de Jobs
            </h3>
            <small class="text-muted">
                Consulta de ejecuciones automáticas y locks activos del sistema.
            </small>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <strong>Locks de jobs</strong>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Job</th>
                            <th>Bloqueado hasta</th>
                            <th>Bloqueado por</th>
                            <th>Última ejecución</th>
                            <th>Actualización</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Locks.Any())
                        {
                            foreach (var item in Model.Locks)
                            {
                                <tr>
                                    <td>@item.NombreJob</td>
                                    <td>@item.LockedUntil.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>@item.LockedBy</td>
                                    <td>@item.FechaUltEjecucion?.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>@item.FechaActualizacion.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    No hay locks registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Últimas ejecuciones</strong>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaJobs" class="table table-striped table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Duración</th>
                            <th>Job</th>
                            <th>Ambiente</th>
                            <th>Estado</th>
                            <th>Generadas</th>
                            <th>Enviadas</th>
                            <th>Errores</th>
                            <th>Mensaje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Ejecuciones)
                        {
                            var estadoClass = item.Estado switch
                            {
                                "FINALIZADO" => "badge bg-success",
                                "ERROR" => "badge bg-danger",
                                "EN_PROCESO" => "badge bg-warning text-dark",
                                _ => "badge bg-secondary"
                            };

                            <tr>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@item.FechaFin?.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>
                                    @(item.DuracionSegundos.HasValue
                                                                    ? $"{item.DuracionSegundos.Value} seg"
                                                                    : "-")
                            </td>
                            <td>@item.NombreJob</td>
                            <td>@item.Ambiente</td>
                            <td><span class="@estadoClass">@item.Estado</span></td>
                            <td>@item.TotalGeneradas</td>
                            <td>@item.TotalEnviadas</td>
                            <td>@item.TotalError</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.MensajeError))
                                    {
                                        <span title="@item.MensajeError">
                                            @(item.MensajeError.Length > 80
                                                                                ? item.MensajeError.Substring(0, 80) + "..."
                                                                                : item.MensajeError)
                                </span>
                                                                }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaJobs').DataTable({
                order: [[0, 'desc']],
                pageLength: 25,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}