@model Alertas.Models.Usuario

@{
    ViewData["Title"] = "Eliminar usuario";
    bool puedeEliminar = ViewBag.PuedeEliminar ?? false;
}

<div class="container mt-4">

    <h3>Eliminar usuario</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            @if (!puedeEliminar)
            {
                <div class="alert alert-warning">
                    Este usuario no puede eliminarse porque tiene obligaciones, proyectos o asignaciones relacionadas.
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    ¿Estás seguro de que deseas eliminar este usuario?
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Usuario</dt>
                <dd class="col-sm-9">@Model.usuario</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.email</dd>

                <dt class="col-sm-3">Super admin</dt>
                <dd class="col-sm-9">@(Model.es_super_admin ? "Sí" : "No")</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_usuario" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>

                    @if (puedeEliminar)
                    {
                        <button type="submit" class="btn btn-danger">
                            Eliminar
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>