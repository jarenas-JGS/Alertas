@model Alertas.ViewModels.UsuarioCreateViewModel

@{
    ViewData["Title"] = "Crear usuario";
}

<div class="container mt-4">

    <h3>Crear usuario</h3>
    <p class="text-muted">Registra un nuevo usuario del sistema. El usuario deberá cambiar la clave en el próximo inicio de sesión.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="usuario" class="form-label">Usuario</label>
                    <input asp-for="usuario" class="form-control" maxlength="30" />
                    <span asp-validation-for="usuario" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="100" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="email" class="form-label">Email</label>
                    <input asp-for="email" class="form-control" maxlength="70" />
                    <span asp-validation-for="email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="clave" class="form-label">Clave inicial</label>
                    <input asp-for="clave" class="form-control" />
                    <span asp-validation-for="clave" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="confirmar_clave" class="form-label">Confirmar clave</label>
                    <input asp-for="confirmar_clave" class="form-control" />
                    <span asp-validation-for="confirmar_clave" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="es_super_admin" class="form-check-input" />
                    <label asp-for="es_super_admin" class="form-check-label">Es super admin</label>
                </div>

                <div class="alert alert-info">
                    Al crear el usuario, se marcará automáticamente para cambio de clave obligatorio en el próximo ingreso.
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}