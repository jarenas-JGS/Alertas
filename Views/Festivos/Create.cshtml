@model Alertas.ViewModels.FestivoViewModel

@{
    ViewData["Title"] = "Crear festivo";
}

<div class="container mt-4">

    <h3>Crear festivo</h3>
    <p class="text-muted">Registra un nuevo día festivo del sistema.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="fecha" class="form-label">Fecha</label>
                    <input asp-for="fecha" type="date" class="form-control" />
                    <span asp-validation-for="fecha" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="150" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}