@model Alertas.Models.GrupoAlerta

@{
    ViewData["Title"] = "Consultar grupo de alerta";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar grupo de alerta</h3>
            <small class="text-muted">Detalle de la información registrada para el grupo de alerta.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información del grupo
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.id_grupo_alerta</dd>

                <dt class="col-sm-3">Proyecto</dt>
                <dd class="col-sm-9">@Model.Proyecto?.nombre</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Relaciones asociadas
        </div>

        <div class="card-body">
            <p class="text-muted mb-3">
                Días asociados al grupo de alerta.
            </p>

            @if (Model.GruposAlertasDias != null && Model.GruposAlertasDias.Any())
            {
                <div class="alert alert-info mb-0">
                    Este grupo tiene @Model.GruposAlertasDias.Count registro(s) asociado(s) en días de alerta.
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Este grupo no tiene días asociados.</p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_grupo_alerta" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Delete" asp-route-id="@Model.id_grupo_alerta" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Eliminar
        </a>
    </div>
</div>