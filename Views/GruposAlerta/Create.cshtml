@model Alertas.ViewModels.GrupoAlertaViewModel

@{
    ViewData["Title"] = "Crear grupo de alerta";
}

<div class="container mt-4">

    <h3>Crear grupo de alerta</h3>
    <p class="text-muted">Registra un grupo de alerta asociado a un proyecto completamente configurado.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="id_proyecto" class="form-label">Proyecto</label>
                    <select asp-for="id_proyecto" asp-items="Model.Proyectos" class="form-select">
                        <option value="">Seleccione...</option>
                    </select>
                    <span asp-validation-for="id_proyecto" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="nombre" class="form-label">Nombre</label>
                    <input asp-for="nombre" class="form-control" maxlength="100" />
                    <span asp-validation-for="nombre" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="activo" class="form-check-input" />
                    <label asp-for="activo" class="form-check-label">Activo</label>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}