@model Alertas.Models.GrupoAlertaDia

@{
    ViewData["Title"] = "Eliminar alerta por días";
    bool puedeEliminar = ViewBag.PuedeEliminar ?? false;
}

<div class="container mt-4">

    <h3>Eliminar alerta por días</h3>

    <div class="card shadow-sm">
        <div class="card-body">

            @if (!puedeEliminar)
            {
                <div class="alert alert-warning">
                    Esta alerta no puede eliminarse porque tiene estados off asociados.
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    ¿Estás seguro de que deseas eliminar esta alerta por días?
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Proyecto</dt>
                <dd class="col-sm-9">@Model.GrupoAlerta?.Proyecto?.nombre</dd>

                <dt class="col-sm-3">Grupo de alerta</dt>
                <dd class="col-sm-9">@Model.GrupoAlerta?.nombre</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.nombre</dd>

                <dt class="col-sm-3">Tipo control</dt>
                <dd class="col-sm-9">@Model.tipo_control</dd>

                <dt class="col-sm-3">Operador</dt>
                <dd class="col-sm-9">@Model.operador</dd>

                <dt class="col-sm-3">Valor días</dt>
                <dd class="col-sm-9">@Model.valor_dias</dd>

                <dt class="col-sm-3">Rol</dt>
                <dd class="col-sm-9">@Model.Rol?.nombre</dd>

                <dt class="col-sm-3">Mensaje</dt>
                <dd class="col-sm-9">@Model.Mensaje?.nombre</dd>

                <dt class="col-sm-3">Dependencia</dt>
                <dd class="col-sm-9">
                    @(Model.Dependencia != null ? Model.Dependencia.nombre : "Sin dependencia")
                </dd>

                <dt class="col-sm-3">Activo</dt>
                <dd class="col-sm-9">
                    @if (Model.activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_grupo_alerta_dia" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>

                    @if (puedeEliminar)
                    {
                        <button type="submit" class="btn btn-danger">
                            Eliminar
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>