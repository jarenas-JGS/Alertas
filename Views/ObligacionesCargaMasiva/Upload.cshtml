@model Alertas.ViewModels.CargaMasiva.CargaObligacionesUploadViewModel

@{
    ViewData["Title"] = "Cargue masivo de obligaciones";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="container-fluid mt-4">

    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">Cargue masivo de obligaciones</h4>
        </div>

        <div class="card-body">

            <div class="alert alert-info">
                <strong>Proyecto:</strong> @Model.nombre_proyecto
            </div>

            <div class="mb-4">
                <a asp-controller="ObligacionesCargaMasiva"
                   asp-action="DescargarPlantilla"
                   asp-route-idProyecto="@Model.id_proyecto"
                   class="btn btn-outline-success">
                    Descargar plantilla Excel
                </a>
            </div>

            <hr />

            <form asp-action="Upload"
                  asp-controller="ObligacionesCargaMasiva"
                  method="post"
                  enctype="multipart/form-data"
                  id="formValidarArchivo">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="id_proyecto" />
                <input type="hidden" asp-for="nombre_proyecto" />

                <div class="mb-3">
                    <label asp-for="archivo" class="form-label">Archivo Excel diligenciado</label>
                    <input asp-for="archivo"
                           type="file"
                           class="form-control"
                           accept=".xlsx" />
                    <span asp-validation-for="archivo" class="text-danger"></span>
                </div>

                <div class="alert alert-warning">
                    Recuerde: si el archivo contiene errores, no se cargará ninguna obligación.
                </div>

                <button type="submit" class="btn btn-primary">
                    Validar archivo
                </button>

                <a asp-controller="RegObl"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>
            </form>

        </div>
    </div>

    <div id="overlayValidacion"
         style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.45);
            z-index:9999;
            align-items:center;
            justify-content:center;">

        <div class="bg-white rounded shadow p-4 text-center" style="max-width:420px;">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Procesando...</span>
            </div>

            <h5>La validación está en proceso</h5>
            <p class="mb-0 text-muted">
                Por favor espere. No cierre esta ventana ni actualice la página.
            </p>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("formValidarArchivo");
            const overlay = document.getElementById("overlayValidacion");

            if (form && overlay) {
                form.addEventListener("submit", function () {
                    overlay.style.display = "flex";

                    const boton = form.querySelector("button[type='submit']");
                    if (boton) {
                        boton.disabled = true;
                        boton.innerText = "Validando...";
                    }
                });
            }
        });
    </script>
}