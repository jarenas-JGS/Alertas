@model Alertas.ViewModels.CambiarPasswordViewModel

@{
    ViewData["Title"] = "Cambiar contraseña";
    Layout = "_Layout";
}

<div class="container mt-4">

    <h3>Cambiar contraseña</h3>
    <p class="text-muted">
        Por seguridad debes cambiar tu contraseña antes de continuar.
    </p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="CambiarPassword" asp-controller="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="ClaveActual" class="form-label">Clave actual</label>
                    <input asp-for="ClaveActual" class="form-control" type="password" autocomplete="current-password" />
                    <span asp-validation-for="ClaveActual" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NuevaClave" class="form-label">Nueva clave</label>
                    <input asp-for="NuevaClave" class="form-control" type="password" autocomplete="new-password" />
                    <span asp-validation-for="NuevaClave" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmarNuevaClave" class="form-label">Confirmar nueva clave</label>
                    <input asp-for="ConfirmarNuevaClave" class="form-control" type="password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmarNuevaClave" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        Cambiar contraseña
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}