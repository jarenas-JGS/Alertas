@model List<Alertas.ViewModels.AccesoProyectoViewModel>

@{
    ViewData["Title"] = "Seleccionar Proyecto";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h2 class="fw-bold mb-1">Seleccionar Proyecto</h2>
                        <p class="text-muted mb-0">
                            Seleccione el proyecto con el que desea trabajar en esta sesión.
                        </p>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-warning">
                            @TempData["Error"]
                        </div>
                    }

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            No se encontraron proyectos disponibles.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var acceso in Model)
                            {
                                <div class="list-group-item px-0 py-3">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                                        <div>
                                            <h5 class="mb-1 fw-semibold">@acceso.nombre_proyecto</h5>
                                            <div class="text-muted small">
                                                Tipo de acceso: @acceso.tipo_acceso
                                            </div>
                                        </div>

                                        <form asp-controller="Login" asp-action="SeleccionarProyecto" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idProyecto" value="@acceso.id_proyecto" />
                                            <input type="hidden" name="tipoAcceso" value="@acceso.tipo_acceso" />

                                            <button type="submit" class="btn btn-primary">
                                                Ingresar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            Volver al inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>