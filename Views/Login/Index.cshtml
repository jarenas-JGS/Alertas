@model Alertas.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-lg border-0" style="width: 420px; border-radius: 16px;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <h3 class="fw-bold mb-2">Iniciar sesión</h3>
                <p class="text-muted mb-0">Sistema de control de impuestos y alertas</p>
            </div>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="usuario" class="form-label fw-semibold"></label>
                    <input asp-for="usuario" class="form-control" placeholder="Ingrese su usuario" />
                    <span asp-validation-for="usuario" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="password" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="password" id="loginPassword" class="form-control" placeholder="Ingrese su contraseña" />
                        <button type="button" class="btn btn-outline-secondary" id="togglePwd" tabindex="-1">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="recordarme" class="form-check-input" />
                    <label asp-for="recordarme" class="form-check-label">
                        Mantener sesión iniciada
                    </label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                        Ingresar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}