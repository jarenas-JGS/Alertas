@model Alertas.Models.GrupoAlertaDiaEstadoOff

@{
    ViewData["Title"] = "Consultar estado off";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">Consultar estado off</h3>
            <small class="text-muted">Detalle del estado que desactiva una alerta por días.</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">
            Información del estado off
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.id_grupo_alerta_dia_estado_off</dd>

                <dt class="col-sm-3">Proyecto</dt>
                <dd class="col-sm-9">@Model.GrupoAlertaDia?.GrupoAlerta?.Proyecto?.nombre</dd>

                <dt class="col-sm-3">Grupo de alerta</dt>
                <dd class="col-sm-9">@Model.GrupoAlertaDia?.GrupoAlerta?.nombre</dd>

                <dt class="col-sm-3">Id alerta</dt>
                <dd class="col-sm-9">@Model.id_grupo_alerta_dia</dd>

                <dt class="col-sm-3">Alerta por días</dt>
                <dd class="col-sm-9">@Model.GrupoAlertaDia?.nombre</dd>

                <dt class="col-sm-3">Estado off</dt>
                <dd class="col-sm-9">@Model.Estado?.nombre</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>

        <a asp-action="Edit" asp-route-id="@Model.id_grupo_alerta_dia_estado_off" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Delete" asp-route-id="@Model.id_grupo_alerta_dia_estado_off" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Eliminar
        </a>
    </div>
</div>